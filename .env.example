# Local demo (SQLite) — works with zero setup
DATABASE_URL="file:./dev.db"

# Production (Postgres) — uncomment and use this instead, and switch
# prisma/schema.prisma provider to "postgresql"
# DATABASE_URL="postgresql://user:password@host:5432/signage"

JWT_SECRET="change-this-to-a-long-random-string"
PORT=4000

# Base URL used to build absolute links to uploaded media (no trailing slash)
PUBLIC_URL="http://localhost:4000"
